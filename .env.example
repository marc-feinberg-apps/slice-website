# Copy to .env for local dev and fill in real values (.env is gitignored).
# In production these must be set in Netlify → Environment variables.
#
# Server-only (no VITE_ prefix) so they never reach the client bundle.
# Used by src/lib/server/supabase.ts for the waitlist/contact lead capture.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
