# Copy to .env for local dev and fill in real values (.env is gitignored).
# In production these must be set in Netlify → Environment variables.
#
# Server-only (no VITE_ prefix) so they never reach the client bundle.
#   SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY — lead capture + privileged reads
#     and signed video URLs (src/lib/server/supabase.ts).
#   SUPABASE_ANON_KEY — user sign-in / cookie session via @supabase/ssr
#     (src/lib/server/supabase-auth.ts). Same Supabase project as the mobile app.

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# SEO / analytics (VITE_ prefix = exposed to the client; these are NOT secrets).
# Both are optional — leave unset and the related tag is simply omitted.
#   VITE_GA_MEASUREMENT_ID — Google Analytics 4 ID, looks like "G-XXXXXXXXXX".
#   VITE_GSC_VERIFICATION  — Google Search Console "HTML tag" verification token
#     (the content="" value only, not the whole <meta> tag).
VITE_GA_MEASUREMENT_ID=
VITE_GSC_VERIFICATION=
